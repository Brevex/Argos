{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "Argos",
  "version": "0.1.0",
  "identifier": "com.argos.app",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Argos",
        "width": 1080,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": false
  },
  "plugins": {}
}
