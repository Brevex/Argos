{
  "productName": "Argos",
  "version": "0.1.0",
  "identifier": "com.argos",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Argos",
        "width": 1000,
        "height": 615,
        "minWidth": 1000,
        "minHeight": 615
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm"],
    "license": "GPL-3.0-only",
    "licenseFile": "LICENSE",
    "publisher": "Argos Authors",
    "copyright": "Copyright (C) 2026 Argos Authors",
    "homepage": "https://github.com/argos",
    "shortDescription": "Forensic image recovery tool",
    "longDescription": "Argos is a desktop forensic tool that recovers permanently-deleted image files from storage devices. It uses Parallel Unique Path (PUP) and Sequential Hypothesis Testing (SHT) for HDD reassembly, and an Aho-Corasick streaming carver for SSDs.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "deb": {
        "desktopTemplate": "resources/argos.desktop",
        "postInstallScript": "scripts/postinst.sh",
        "files": {
          "/usr/share/polkit-1/actions/com.argos.policy": "resources/linux/com.argos.policy"
        }
      },
      "rpm": {
        "desktopTemplate": "resources/argos.desktop",
        "postInstallScript": "scripts/postinst.sh",
        "files": {
          "/usr/share/polkit-1/actions/com.argos.policy": "resources/linux/com.argos.policy"
        }
      }
    }
  },
  "plugins": {}
}
