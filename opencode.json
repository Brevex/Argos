{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/rust-style.md",
    ".opencode/instructions/tauri-patterns.md",
    ".opencode/instructions/forensics-rules.md",
    ".opencode/instructions/algorithms-spec.md",
    ".opencode/instructions/security-baseline.md"
  ],
  "permission": {
    "edit": "ask",
    "webfetch": "ask",
    "bash": {
      "cargo check*": "allow",
      "cargo build*": "allow",
      "cargo test*": "allow",
      "cargo bench*": "allow",
      "cargo clippy*": "allow",
      "cargo fmt*": "allow",
      "cargo doc*": "allow",
      "cargo tree*": "allow",
      "cargo audit*": "allow",
      "cargo deny*": "allow",
      "cargo geiger*": "allow",
      "cargo fuzz*": "ask",
      "pnpm install*": "ask",
      "pnpm typecheck*": "allow",
      "pnpm lint*": "allow",
      "pnpm test*": "allow",
      "pnpm tauri dev*": "ask",
      "pnpm tauri build*": "ask",
      "git status": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "find*": "allow",
      "rm*": "deny",
      "rm -rf*": "deny",
      "dd*": "deny",
      "sudo*": "deny",
      "mkfs*": "deny",
      "mount*": "deny",
      "umount*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "wipefs*": "deny",
      "shred*": "deny",
      "*": "ask"
    }
  }
}
